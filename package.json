require("dotenv").config();

const express = require("express");
const jwt = require("jsonwebtoken");
const bcrypt = require("bcryptjs");
const rateLimit = require("express-rate-limit");

const app = express();
app.use(express.json());

/**
 * ⚙️ CONFIG
 */
const SECRET_KEY = process.env.SECRET_KEY || "vanminh_dep_trai";

/**
 * 👑 ADMIN (hardcode)
 * password: 123456
 */
const admins = [
  {
    username: "vanminh2603",
    password: "$2a$10$7QJ9wZlYQ9QK1nC1mQzX9e1Vw0v5QzYt6QZcH8H0zR0sZl9R6Hk9K",
    role: "admin"
  }
];

/**
 * 🛡️ RATE LIMIT
 */
const limiter = rateLimit({
  windowMs: 15 * 60 * 1000,
  max: 100
});

app.use(limiter);

/**
 * 🔐 AUTH MIDDLEWARE
 */
function authenticateToken(req, res, next) {
  const authHeader = req.headers["authorization"];
  const token = authHeader && authHeader.split(" ")[1];

  if (!token) return res.status(401).json({ message: "Thiếu token" });

  jwt.verify(token, SECRET_KEY, (err, user) => {
    if (err) return res.status(403).json({ message: "Token không hợp lệ" });
    req.user = user;
    next();
  });
}

/**
 * 👑 ADMIN CHECK
 */
function requireAdmin(req, res, next) {
  if (req.user.role !== "admin") {
    return res.status(403).json({ message: "Cần quyền admin" });
  }
  next();
}

/**
 * 🌐 (OPTION) CHECK IP ADMIN
 */
const allowedIPs = ["127.0.0.1", "::1"];

function checkIP(req, res, next) {
  const ip = req.ip;
  if (!allowedIPs.includes(ip)) {
    return res.status(403).json({ message: "IP không được phép" });
  }
  next();
}

/**
 * 🔐 LOGIN
 */
app.post("/login", async (req, res) => {
  const { username, password } = req.body;

  const user = admins.find(u => u.username === username);
  if (!user) {
    return res.status(401).json({ message: "Sai tài khoản" });
  }

  const isMatch = await bcrypt.compare(password, user.password);
  if (!isMatch) {
    return res.status(401).json({ message: "Sai mật khẩu" });
  }

  const token = jwt.sign(
    { username: user.username, role: user.role },
    SECRET_KEY,
    { expiresIn: "12h" }
  );

  console.log(`✅ Admin login: ${username}`);

  res.json({ token });
});

/**
 * 🌍 PUBLIC API
 */
app.get("/api/data", (req, res) => {
  res.json({ message: "API public OK" });
});

/**
 * 🔓 USER API
 */
app.get("/api/user", authenticateToken, (req, res) => {
  res.json({
    message: "User OK",
    user: req.user
  });
});

/**
 * 👑 ADMIN API
 */
app.get(
  "/api/admin",
  authenticateToken,
  requireAdmin,
  // checkIP, // bật nếu cần
  (req, res) => {
    res.json({
      message: "Admin toàn quyền 👑",
      user: req.user
    });
  }
);

/**
 * 🧠 API QUẢN LÝ (ví dụ cho soi cầu)
 */
app.post(
  "/api/admin/update",
  authenticateToken,
  requireAdmin,
  (req, res) => {
    console.log("⚙️ Admin update:", req.body);

    res.json({
      message: "Đã cập nhật hệ thống",
      data: req.body
    });
  }
);

/**
 * 🚀 START SERVER
 */
app.listen(3000, () => {
  console.log("🚀 Server chạy tại http://localhost:3000");
});
